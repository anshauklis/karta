# Karta environment variables
# These are auto-generated by install.sh — you can also set them manually.

POSTGRES_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
CONNECTION_SECRET=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
PORT=8090
NEXTAUTH_URL=http://localhost:8090

# For SSL mode (./install.sh --ssl):
# DOMAIN=charts.example.com

# MCP server (docker compose --profile mcp up -d):
# MCP_PORT=8811
# MCP_USER_EMAIL=admin@example.com
# MCP_USER_PASSWORD=your-password

# Comma-separated list of allowed CORS origins (empty = defaults to NEXTAUTH_URL)
# CORS_ORIGINS=https://charts.example.com

# Set to false to enable Swagger/OpenAPI docs (disabled by default in Docker)
# DISABLE_DOCS=false
